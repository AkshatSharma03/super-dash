# Server-side only — never expose this to the browser
ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# Kimi 2.5 query canonicalization (optional — falls back to built-in normaliser if not set)
KIMI_API_KEY=your_kimi_api_key_here
# KIMI_MODEL=moonshot-v1-8k   # default; override if you have access to a newer model
