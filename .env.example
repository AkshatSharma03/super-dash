# Server-side only — never expose this to the browser
ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# Clerk authentication
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
# Optional: enables networkless Clerk JWT verification in the backend
# CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Client-side Clerk key (Vite)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx

# Kimi 2.5 query canonicalization (optional — falls back to built-in normaliser if not set)
KIMI_API_KEY=your_kimi_api_key_here
# KIMI_MODEL=moonshot-v1-8k   # default; override if you have access to a newer model

# Kagi FastGPT search + summarization (optional but recommended for Search mode)
KAGI_API_KEY=your_kagi_api_key_here
# KAGI_BASE=https://kagi.com/api/v0

# Stripe billing (optional — paid features are disabled without these)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
